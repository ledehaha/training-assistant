# ============================================
# 培训助手系统 - 环境变量配置
# ============================================
# 请复制此文件为 .env 并填入实际值

# ============================================
# 数据库配置（SQLite）
# ============================================
# 数据库文件路径（可选，默认 /data/training.db）
# 本地开发时可使用 ./data/training.db
DATABASE_PATH=/data/training.db

# ============================================
# Coze API 配置（AI 功能必需）
# ============================================
# 从 Coze 平台获取：https://www.coze.cn/open/oauth/pats
COZE_API_KEY=your_coze_api_key

# 对象存储配置（文件上传功能需要）
COZE_BUCKET_ENDPOINT_URL=your_s3_endpoint_url
COZE_BUCKET_NAME=your_bucket_name

# ============================================
# 应用配置
# ============================================
APP_URL=http://localhost:5000
