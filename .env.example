# ============================================
# 培训助手系统 - 环境变量配置
# ============================================
# 请复制此文件为 .env 并填入实际值

# ============================================
# 数据库配置（Docker 部署自动配置，无需修改）
# ============================================
DB_USER=training_user
DB_PASSWORD=your_secure_password_here
DB_NAME=training_db

# ============================================
# Supabase 数据库配置（使用远程数据库时填写）
# ============================================
# 从 Supabase 控制台获取：Project Settings → API
COZE_SUPABASE_URL=https://xxxxx.supabase.co
COZE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# Coze API 配置（AI 功能必需）
# ============================================
# 从 Coze 平台获取：https://www.coze.cn/open/oauth/pats
COZE_API_KEY=your_coze_api_key

# 对象存储配置（文件上传功能需要）
COZE_BUCKET_ENDPOINT_URL=your_s3_endpoint_url
COZE_BUCKET_NAME=your_bucket_name

# ============================================
# 应用配置
# ============================================
APP_URL=http://localhost:5000
