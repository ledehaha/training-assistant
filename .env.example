# ============================================
# 培训助手系统 - 环境变量配置
# ============================================
# 请复制此文件为 .env 并填入实际值

# ============================================
# 数据库配置
# ============================================
DB_USER=training_user
DB_PASSWORD=your_secure_password_here
DB_NAME=training_db

# ============================================
# Coze API 配置（必填）
# ============================================
COZE_API_KEY=your_coze_api_key_here
COZE_BUCKET_ENDPOINT_URL=your_s3_endpoint_url
COZE_BUCKET_NAME=your_bucket_name

# ============================================
# 应用配置
# ============================================
APP_URL=http://localhost:5000
