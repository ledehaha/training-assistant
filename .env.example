# ============================================
# 培训助手系统 - 环境变量配置
# ============================================
# 请复制此文件为 .env 并填入实际值

# ============================================
# 数据存储配置（本地存储）
# ============================================
# 数据库文件路径（可选，默认 ./data/training.db）
DATA_DIR=/data

# 文件存储路径（可选，默认 /data/files）
FILE_STORAGE_PATH=/data/files

# ============================================
# Coze API 配置（AI 功能，可选）
# ============================================
# 如果不配置，AI 智能推荐功能将不可用
# 但 Excel 文件导入仍然可用
# 
# 从 Coze 平台获取：https://www.coze.cn/open/oauth/pats
# COZE_API_KEY=your_coze_api_key

# ============================================
# 应用配置
# ============================================
APP_URL=http://localhost:5000
