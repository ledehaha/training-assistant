# ============================================
# 培训助手系统 - 环境变量配置
# ============================================
# 请复制此文件为 .env 并填入实际值

# ============================================
# 数据库配置（必填）
# ============================================
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://training_user:your_password@localhost:5432/training_db

# ============================================
# Coze API 配置（必填）
# ============================================
# Coze API 密钥
COZE_API_KEY=your_coze_api_key_here

# S3 存储端点 URL
COZE_BUCKET_ENDPOINT_URL=https://your-s3-endpoint.com

# 存储桶名称
COZE_BUCKET_NAME=your-bucket-name

# ============================================
# 应用配置
# ============================================
# 运行环境
NODE_ENV=production

# 应用端口
PORT=5000

# 应用 URL（用于生成链接）
NEXT_PUBLIC_APP_URL=http://your-nas-ip:5000

# ============================================
# 可选配置
# ============================================
# 日志级别
# LOG_LEVEL=info

# 会话密钥（用于加密）
# SESSION_SECRET=your-random-secret-key
