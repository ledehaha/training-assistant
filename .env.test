# 测试环境配置
# 此文件用于测试环境的环境变量配置

# Node.js 环境
NODE_ENV=test

# 端口配置
PORT=5001
HOST=localhost

# API 配置
API_BASE_URL=http://localhost:5001/api

# 数据库配置
DATABASE_URL=file:./data/training-test.db

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# 调试配置
DEBUG=false
SOURCE_MAP=false

# 性能配置
PERFORMANCE_MONITORING=true
INSTALL_TIME_TRACKING=true

# 缓存配置
CACHE_ENABLED=false
CACHE_TTL=0

# 特性开关
FEATURE_AI_ENABLED=true
FEATURE_AUTO_CLEAN=false
FEATURE_AUTO_UPDATE_CHECK=true

# 安全配置
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5001

# 测试配置
TEST_TIMEOUT=30000
TEST_RETRIES=3

# 构建配置
NEXT_TELEMETRY_DISABLED=1
