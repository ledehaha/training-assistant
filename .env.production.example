# 端口配置
PORT=5000
NODE_ENV=production

# 数据库配置 (从 Supabase 控制台获取)
DATABASE_URL=your_supabase_connection_string
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 如果使用阿里云 RDS PostgreSQL，替换为：
# DATABASE_URL=postgresql://username:password@rds-host:5432/database_name
